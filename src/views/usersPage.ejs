<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(u=> { %>
                    <tr>
                        <td>
                            <%= u.name %>
                        </td>
                        <td>
                            <%= u.email %>
                        </td>
                        <td>
                            <%= u.role_name %>
                        </td>
                    </tr>
                    <% }); %>
            </tbody>
        </table>
    </main>
    <%- include('partials/footer') %>