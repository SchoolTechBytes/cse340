<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2>Upcoming Service Projects</h2>
    <ul>

        <% projects.forEach(project => { %>
        <li>
            <!--We are formating the date here so that it displays as 6/15/2026 and not the CDT format-->
            Date: <%= project.project_date.toLocaleDateString() %>
            <br>
            <%= project.title %> (<%= project.organization_name %>)
        </li>

        <% }); %>
    </ul>

</main>

<%- include('partials/footer') %>