<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>
            <%= projectDetails.title %>
        </h2>
        <p>Description: <%= projectDetails.description %>
        </p>
        <p>Date: <%= projectDetails.project_date.toLocaleDateString() %>
        </p>
        <p>Location: <%= projectDetails.location %>
        </p>
        <p>Organization:<a href="/organization/<%= projectDetails.organization_id %>">
                <%= projectDetails.organization_name %>
            </a></p>

        <div class="tags">
            <% categories.forEach(category=> { %>
                <a href="/category/<%= category.category_id %>" class="tag">
                    <%= category.name %>
                </a>
                <% }); %>
        </div>
        <div class="volButton">
            <% if (isLoggedIn) { %>
                <% if (isVolunteering) { %>
                    <p class="vol-status">&#10003; You are volunteering for this project</p>
                    <form action="/project/<%= projectDetails.project_id %>/unvolunteer" method="POST">
                        <button type="submit" class="btn btn-danger">Remove me as a volunteer</button>
                    </form>
                <% } else { %>
                    <form action="/project/<%= projectDetails.project_id %>/volunteer" method="POST">
                        <button type="submit" class="btn btn-primary">Volunteer for this project</button>
                    </form>
                <% } %>
            <% } %>
        </div>

        <div>
            <% if (user && user.role_name==='admin' ) { %>
                <p><a href="/assign-categories/<%= projectDetails.project_id %>">Edit Categories</a></p>
                <p><a href="/edit-project/<%= projectDetails.project_id %>">Edit Project</a></p>
                <% } %>
        </div>
    </main>
    <%- include('partials/footer') %>