<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2>Categories</h2>
    <ul>

        <% categories.forEach(categories => { %>
        <li><a href="/category/<%= categories.category_id %>"><%=
                categories.name %></a></li>

        <% }); %>
    </ul>

</main>

<%- include('partials/footer') %>